@incollection{Furlong2018,
abstract = {Drug addiction is characterized in part by a lack of flexible control over drug-related behaviors. This could be the result of strengthening drug-related habits or diminished goal-directed control. The present chapter reviews research on the effects of drugs of abuse on the medial and lateral subregions of the dorsal striatum known to mediate goal-directed and habitual behaviors. Evidence is presented, which demonstrates that drugs of abuse can cause persistent neuroplastic changes to both the goal-directed and habit systems. Importantly, it is also demonstrated that goal-directed control can be rescued by interventions that either decrease activity of the dorsolateral striatal habit system or promote or normalize activity in the dorsomedial striatal goal-directed system. Identifying when habits dominate behavioral control and localizing changes to underlying circuits will be essential for developing the most effective treatments to restore behavioral control in drug addiction.},
author = {Furlong, Teri M and Corbit, Laura H},
booktitle = {Goal-Directed Decision Making: Computations and Neural Circuits},
doi = {10.1016/B978-0-12-812098-9.00016-4},
file = {:Users/qianliyang/OneDriveNew/OneDrive/Reference/Furlong, Corbit/Furlong, Corbit - Goal-Directed Decision Making Computations and Neural Circuits - 2018.pdf:pdf},
isbn = {9780128120989},
keywords = {Addiction,Alcohol,Dopamine,Glutamate,Goal-directed action,Habits,Learning,Outcome devaluation,Psychostimulants,Substance abuse},
pages = {367--386},
publisher = {Elsevier Inc.},
title = {{Drug addiction: Augmented habit learning or failure of goal-directed control?}},
url = {http://dx.doi.org/10.1016/B978-0-12-812098-9.00016-4},
year = {2018}
}
@incollection{Morris2018,
abstract = {Deficits in emotion and motivation have long been noted in schizophrenia, where a disconnect between hedonic value and motivated behavior is considered a core feature. Theories of goal-directed learning emphasize the close integration between reward value and action selection, and I argue they can help us understand the form and consequences of the disconnection in schizophrenia. In particular, recent developments in model-based reinforcement learning have highlighted three requirements for goal-directed decision-making: learning a mental map of the environment, learning where reward is located within that map, and integrating the reward value back to the current action. As such, much of the evidence used to infer a deficit in goal-directed decision-making in schizophrenia has to be reassessed in light of our improved understanding. However, contemporary evidence is emerging, which promises to reveal the underlying processes impaired in schizophrenia. Evidence that an impairment in integrating reward value over a causal map of the environmental is presented, and its implications for future research are discussed.},
author = {Morris, Richard W},
booktitle = {Goal-Directed Decision Making: Computations and Neural Circuits},
doi = {10.1016/B978-0-12-812098-9.00017-6},
file = {:Users/qianliyang/OneDriveNew/OneDrive/Reference/Morris/Morris - Goal-Directed Decision Making Computations and Neural Circuits - 2018.pdf:pdf},
isbn = {9780128120989},
keywords = {Causal learning,Contingency degradation,Goal-directed learning,Outcome devaluation,Psychosis},
pages = {387--406},
title = {{Goal-directed deficits in schizophrenia}},
year = {2018}
}
@incollection{Bhui2018,
abstract = {This chapter presents an emerging “case-based” system for decision-making that centers on the retrieval of similar past episodes. It can be mathematically described by the economic model of case-based decision theory accompanied by the computational background of case-based reasoning. This system stands between model-free and model-based systems on the bias-variance trade-off and holds advantages over both when faced with novel and complex problems. The hippocampus and related medial temporal lobe structures provide a neural substrate for case-based calculations by instantiating stimulus and reward associations. This neurocomputational understanding sheds light on how such calculations can also contribute to or interfere with model-free and model-based control.},
author = {Bhui, Rahul},
booktitle = {Goal-Directed Decision Making: Computations and Neural Circuits},

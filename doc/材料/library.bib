author = {Li, Yangang and Zhu, Xinyun and Qi, Yu and Wang, Yueming},
file = {:Users/qianliyang/OneDriveNew/OneDrive/Reference/Li et al/Li et al. - bioRxiv - 2023.pdf:pdf},
journal = {bioRxiv},
title = {{Revealing unexpected complex encoding but simple decoding mechanisms in motor cortex via separating task-relevant neural signals}},
year = {2023}

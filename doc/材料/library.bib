author = {Scherrer, Nino and Bilaniuk, Olexa and Annadani, Yashas and Goyal, Anirudh and Schwab, Patrick and Sch{\"{o}}lkopf, Bernhard and Mozer, Michael C. and Bengio, Yoshua and Bauer, Stefan and Ke, Nan Rosemary},

@article{Charpentier2021,
abstract = {Reinforcement learning algorithms describe how an agent can learn an optimal action policy in a sequential decision process, through repeated experience. In a given environment, the agent policy provides him some running and terminal rewards. As in online learning, the agent learns sequentially. As in multi-armed bandit problems, when an agent picks an action, he can not infer ex-post the rewards induced by other action choices. In reinforcement learning, his actions have consequences: they influence not only rewards, but also future states of the world. The goal of reinforcement learning is to find an optimal policy – a mapping from the states of the world to the set of actions, in order to maximize cumulative reward, which is a long term strategy. Exploring might be sub-optimal on a short-term horizon but could lead to optimal long-term ones. Many problems of optimal control, popular in economics for more than forty years, can be expressed in the reinforcement learning framework, and recent advances in computational science, provided in particular by deep learning algorithms, can be used by economists in order to solve complex behavioral problems. In this article, we propose a state-of-the-art of reinforcement learning techniques, and present applications in economics, game theory, operation research and finance.},
archivePrefix = {arXiv},
arxivId = {2003.10014},
author = {Charpentier, Arthur and {\'{E}}lie, Romuald and Remlinger, Carl},
doi = {10.1007/s10614-021-10119-4},
eprint = {2003.10014},
file = {:Users/qianliyang/OneDriveNew/OneDrive/Reference/Charpentier, {\'{E}}lie, Remlinger/Charpentier, {\'{E}}lie, Remlinger - Computational Economics - 2021.pdf:pdf},
issn = {15729974},
journal = {Computational Economics},
keywords = {Causality,Control,Machine learning,Markov decision process,Multi-armed bandits,Online-learning,Q-learning,Regret,Reinforcement learning,Rewards,Sequential learning},
number = {March},
title = {{Reinforcement Learning in Economics and Finance}},
year = {2021}
}
@article{Taylor2018,
abstract = {Reinforcement learning (RL) has had many successes when learning autonomously. This paper and accompanying talk consider how to make use of a non-technical human participant, when available. In particular, we consider the case where a human could 1) provide demonstrations of good behavior, 2) provide online evaluative feedback, or 3) define a curriculum of tasks for the agent to learn on. In all cases, our work has shown such information can be effectively leveraged. After giving a high-level overview of this work, we will highlight a set of open questions and suggest where future work could be usefully focused.},
author = {Taylor, Matthew E.},
doi = {10.24963/ijcai.2018/817},
file = {:Users/qianliyang/OneDriveNew/OneDrive/Reference/Taylor/Taylor - IJCAI International Joint Conference on Artificial Intelligence - 2018.pdf:pdf},
isbn = {9780999241127},
issn = {10450823},
journal = {IJCAI International Joint Conference on Artificial Intelligence},
keywords = {Humans and AI: Human-Computer Interaction,Machine Learning: Reinforcement Learning,Machine Learning: Transfer & Adaptation & Multi-ta},
pages = {5724--5728},
title = {{Improving reinforcement learning with human input}},
volume = {2018-July},
year = {2018}
}
@article{Stolle2002a,
abstract = {Temporally extended actions (e.g., macro actions) have proven very useful for speeding up learning, ensuring robustness and building prior knowledge into AI systems. The options framework (Precup, 2000; Sutton, Precup & Singh, 1999) provides a natural way of incorporating such actions into reinforcement learning systems, but leaves open the issue of howgood options might be identified. In this paper, we empirically explore a simple approach to creating options. The underlying assumption is that the agent will be asked to perform different goalachievement tasks in an environment that is otherwise the same over time. Our approach is based on the intuition that states that are frequently visited on system trajectories, could prove to be useful subgoals (e.g., McGovern & Barto, 2001; Iba, 1989). We propose a greedy algorithm for identifying subgoals based on state visitation counts.We present empirical studies of this approach in two gridworld navigation tasks. One of the environments we explored contains bottleneck states, and the algorithm indeed finds these states, as expected. The second environment is an empty gridworld with no obstacles. Although the environment does not contain any obvious subgoals, our approach still finds useful options, which essentially allow the agent to explore the environment more quickly.},
author = {Stolle, Martin and Precup, Doina},
doi = {10.1007/3-540-45622-8_16},
file = {:Users/qianliyang/OneDriveNew/OneDrive/Reference/Stolle, Precup/Stolle, Precup - Lecture Notes in Computer Science (including subseries Lecture Notes in Artificial Intelligence and Lecture Notes in Bi.pdf:pdf},
isbn = {3540439412},
issn = {16113349},
journal = {Lecture Notes in Computer Science (including subseries Lecture Notes in Artificial Intelligence and Lecture Notes in Bioinformatics)},
pages = {212--223},
title = {{Learning options in reinforcement learning}},
volume = {2371},
year = {2002}
}
@article{Mobley2020,
abstract = {Reinforcement Learning has the limitation that problems become too large very quickly. Dividing the problem into a hierarchy of subtasks allows for a strategy of divide and conquer, which is what makes Hierarchical Reinforcement Learning (HRL) algorithms often more efficient at finding solutions quicker than more n{\"{a}}ive approaches. One of the biggest challenges with HRL is the construction of a hierarchy to be used by the algorithm. Hierarchies are often designed by a human author using their own knowledge of the problem. We propose a method for automatically discovering task hierarchies based on a data mining technique, Association Rule Learning (ARL). These hierarchies can then be applied to SemiMarkov Decision Process (SMDP) problems using the options technique.},
author = {Mobley, Dave and Harrison, Brent and Goldsmith, Judy},
file = {:Users/qianliyang/OneDriveNew/OneDrive/Reference/Mobley, Harrison, Goldsmith/Mobley, Harrison, Goldsmith - Proceedings of the 33rd International Florida Artificial Intelligence Research Society Conference, FLAIRS.pdf:pdf},
isbn = {9781577358213},
journal = {Proceedings of the 33rd International Florida Artificial Intelligence Research Society Conference, FLAIRS 2020},
keywords = {Special Track on Autonomous Robots and Agents},
pages = {392--395},
title = {{Discovering hierarchy for reinforcement learning using data mining}},
year = {2020}
}
@inproceedings{Simsek2004,
abstract = {We present a new method for automatically creating useful temporal abstractions in reinforcement learning. We argue that states that allow the agent to transition to a different region of the state space are useful sub-goals, and propose a method for identifying them using the concept of relative novelty. When such a state is identified, a temporally-extended activity (e.g., an option) is generated that takes the agent efficiently to this state. We illustrate the utility of the method in a number of tasks.},
address = {New York, New York, USA},
author = {Şimşek, {\"{O}}zg{\"{u}}r and Barto, Andrew G.},
booktitle = {Twenty-first international conference on Machine learning - ICML '04},

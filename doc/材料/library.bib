keywords = {Technical Papers -- Machine Learning},
pages = {431--436},
title = {{Properties of Bayesian Dirichlet scores to learn Bayesian network structures}},
volume = {1},
year = {2010}
}
@article{Pomeranz2011,
abstract = {In the square jigsaw puzzle problem one is required to reconstruct the complete image from a set of non-overlapping, unordered, square puzzle parts. Here we propose a fully automatic solver for this problem, where unlike some previous work, it assumes no clues regarding parts' location and requires no prior knowledge about the original image or its simplified (e.g., lower resolution) versions. To do so, we introduce a greedy solver which combines both informed piece placement and rearrangement of puzzle segments to find the final solution. Among our other contributions are new compatibility metrics which better predict the chances of two given parts to be neighbors, and a novel estimation measure which evaluates the quality of puzzle solutions without the need for ground-truth information. Incorporating these contributions, our approach facilitates solutions that surpass state-of-the-art solvers on puzzles of size larger than ever attempted before. {\textcopyright} 2011 IEEE.},
author = {Pomeranz, Dolev and Shemesh, Michal and Ben-Shahar, Ohad},
doi = {10.1109/CVPR.2011.5995331},
file = {:Users/qianliyang/OneDriveNew/OneDrive/Reference/Pomeranz, Shemesh, Ben-Shahar/Pomeranz, Shemesh, Ben-Shahar - Proceedings of the IEEE Computer Society Conference on Computer Vision and Pattern Recognition - 2011.pdf:pdf},
isbn = {9781457703942},
issn = {10636919},
journal = {Proceedings of the IEEE Computer Society Conference on Computer Vision and Pattern Recognition},
pages = {9--16},
title = {{A fully automated greedy square jigsaw puzzle solver}},
year = {2011}
}
